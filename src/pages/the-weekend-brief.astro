---
import Base from '../layouts/Base.astro';
---
<Base
  title="The Weekend Brief - Made the Weekend"
  description="One email every Thursday: where to go this weekend, one place to stay worth it, and one thing to skip."
>
<section class="page-head">
  <div class="inner" style="max-width:760px;margin:0 auto;text-align:center;">
    <svg class="page-motif" width="120" height="44" viewBox="0 0 120 44" fill="none" aria-hidden="true" style="margin:0 auto;">
  <path d="M4 40 C 30 34, 40 22, 60 20 C 74 18.5, 82 17, 89 14" stroke="#E0A45C" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="0.5 7" opacity="0.8"></path>
  <path d="M98 2 C 101.3 2, 104 4.7, 104 8 C 104 12.5, 98 17.5, 98 17.5 C 98 17.5, 92 12.5, 92 8 C 92 4.7, 94.7 2, 98 2 Z" stroke="#E0A45C" stroke-width="1.4" fill="none"></path>
  <circle cx="98" cy="7.8" r="1.8" fill="#E0A45C"></circle>
</svg>
    <p class="eyebrow">The Weekend Brief</p>
    <h1>One email, every Thursday</h1>
    <p class="lede" style="margin-left:auto;margin-right:auto;">By Thursday evening you'll know where you're going. Each issue picks one weekend that suits the forecast, one place to stay that's worth the money, and one thing everyone recommends that you can safely skip.</p>
  </div>
</section>
<section class="light" style="padding-top:clamp(48px,7vw,72px);padding-bottom:clamp(64px,9vw,100px);">
  <div class="wrap" style="max-width:760px;text-align:center;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;margin-bottom:44px;text-align:left;">
      <div><h3 style="font-family:Fraunces,serif;font-size:20px;color:var(--forest-deep);margin-bottom:8px;">One destination</h3><p style="margin:0;color:var(--ink-soft);font-size:14.5px;line-height:1.6;">Chosen for that weekend's weather, not a listicle of ten.</p></div>
      <div><h3 style="font-family:Fraunces,serif;font-size:20px;color:var(--forest-deep);margin-bottom:8px;">One place to stay</h3><p style="margin:0;color:var(--ink-soft);font-size:14.5px;line-height:1.6;">Slept in by us, with the room number to ask for.</p></div>
      <div><h3 style="font-family:Fraunces,serif;font-size:20px;color:var(--forest-deep);margin-bottom:8px;">One thing to skip</h3><p style="margin:0;color:var(--ink-soft);font-size:14.5px;line-height:1.6;">And what to do with the hours you get back.</p></div>
    </div>

    <!-- ===== Newsletter signup (posts to /api/subscribe -> Beehiiv) ===== -->
    <div id="brief-form-wrap">
      <div class="brief-form" style="justify-content:center;max-width:520px;margin:0 auto;">
        <input type="email" id="brief-email" placeholder="you@example.com" aria-label="Email address">
        <button id="brief-signup">Sign up</button>
      </div>
      <p id="brief-error" role="alert" hidden style="margin:12px 0 0;color:var(--clay);font-size:13.5px;"></p>
      <p class="fineprint">Free. Read in three minutes. Unsubscribe whenever.</p>
    </div>
    <p class="done" id="brief-done" hidden>You're in. See you Thursday.</p>

    <!--
      ===== PAST ISSUE PREVIEW: hidden until we send our first real Brief =====
      REMINDER: once the first newsletter goes out, replace the placeholder below
      with the real issue (number, date, destination, stay, skip) and remove the
      hidden attribute on the wrapper div to show it.
    -->
    <div hidden style="margin-top:56px;padding-top:32px;border-top:1px solid rgba(28,36,29,0.14);text-align:left;">
      <p class="eyebrow" style="color:var(--clay);margin-bottom:14px;">Last week's issue</p>
      <h2 style="font-family:Fraunces,serif;font-weight:600;font-size:clamp(24px,3.4vw,32px);color:var(--forest-deep);margin-bottom:14px;">[Issue headline]</h2>
      <p style="margin:0 0 18px;color:var(--ink-soft);font-size:15px;line-height:1.65;max-width:60ch;">[One-paragraph summary of the destination.]</p>
      <p style="margin:0 0 6px;color:var(--forest-deep);font-size:14.5px;"><strong>Stay</strong> - [the place].</p>
      <p style="margin:0;color:var(--forest-deep);font-size:14.5px;"><strong>Skip</strong> - [the thing to skip].</p>
    </div>
  </div>
</section>
<script>
(function(){
  var btn=document.getElementById('brief-signup'); if(!btn) return;
  btn.addEventListener('click',function(){
    var input=document.getElementById('brief-email');
    var email=input.value.trim();
    if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){input.focus();return;}
    var errEl=document.getElementById('brief-error');
    if(errEl) errEl.hidden=true;
    btn.disabled=true; btn.textContent='Signing you up...';
    fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:email})})
      .then(function(r){return r.json().catch(function(){return {ok:false};});})
      .then(function(data){
        if(data&&data.ok){
          document.getElementById('brief-form-wrap').hidden=true;
          document.getElementById('brief-done').hidden=false;
        } else {
          btn.disabled=false; btn.textContent='Sign up';
          if(errEl){errEl.textContent=(data&&data.error)||'Could not sign you up just now. Please try again.'; errEl.hidden=false;}
        }
      }).catch(function(){
        btn.disabled=false; btn.textContent='Sign up';
        if(errEl){errEl.textContent='Could not sign you up just now. Please try again.'; errEl.hidden=false;}
      });
  });
})();
</script>
</Base>
