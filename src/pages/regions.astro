---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const published = (await getCollection('guide')).filter((g) => g.data.published);

// Group guides by region
const map = new Map();
for (const g of published) {
  const r = g.data.region;
  if (!map.has(r)) map.set(r, []);
  map.get(r).push(g);
}
const regions = Array.from(map.entries())
  .map(([name, gs]) => ({
    name,
    count: gs.length,
    hero: gs.find((g) => g.data.heroImage)?.data.heroImage || '',
    heroAlt: gs.find((g) => g.data.heroImage)?.data.heroAlt || name,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---
<Base
  title="Regions - Made the Weekend"
  description="UK weekend guides grouped by region. Deep local coverage, added as we get to know each corner."
>
<section class="page-head">
  <div class="inner">
    <svg class="page-motif" width="120" height="44" viewBox="0 0 120 44" fill="none" aria-hidden="true">
  <path d="M4 40 C 30 34, 40 22, 60 20 C 74 18.5, 82 17, 89 14" stroke="#E0A45C" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="0.5 7" opacity="0.8"></path>
  <path d="M98 2 C 101.3 2, 104 4.7, 104 8 C 104 12.5, 98 17.5, 98 17.5 C 98 17.5, 92 12.5, 92 8 C 92 4.7, 94.7 2, 98 2 Z" stroke="#E0A45C" stroke-width="1.4" fill="none"></path>
  <circle cx="98" cy="7.8" r="1.8" fill="#E0A45C"></circle>
</svg>
    <p class="eyebrow">Browse by region</p>
    <h1>Where do you fancy?</h1>
    <p class="lede">Each corner covered as we get to know it. More regions join the map as we drive them.</p>
  </div>
</section>
<section class="light" style="padding-top:clamp(48px,7vw,72px);padding-bottom:clamp(64px,9vw,100px);">
  <div class="wrap">
    {regions.length === 0 ? (
      <p style="color:var(--sage);font-size:16px;">The first regions are being written now. Join <a href="/the-weekend-brief" style="font-weight:600;">the Brief</a> to hear when they land.</p>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:32px;">
        {regions.map((r) => (
          <a class="r-card" href={`/regions/${r.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} style="display:flex;flex-direction:column;text-decoration:none;">
            <div class="thumb" style="position:relative;border-radius:6px;overflow:hidden;aspect-ratio:3/2;background:var(--forest);">
              <div class={`img ${r.hero ? 'has-photo' : ''}`} style={r.hero ? `background-image:url('${r.hero}')` : ''} data-ph={r.heroAlt}></div>
            </div>
            <h3 style="font-family:Fraunces,serif;font-weight:600;font-size:22px;color:var(--forest-deep);margin:14px 0 6px;">{r.name}</h3>
            <span class="count" style="color:var(--clay);font-size:14px;font-weight:600;">{r.count} {r.count === 1 ? 'guide' : 'guides'} →</span>
          </a>
        ))}
      </div>
    )}
    <p style="margin-top:clamp(40px,6vw,56px);color:var(--sage);font-size:14.5px;line-height:1.6;max-width:56ch;">Somewhere missing? The next region gets covered when we've driven it, not before. Tell us where to go via <a href="/the-weekend-brief" style="font-weight:600;">the Brief</a>.</p>
  </div>
</section>
</Base>
