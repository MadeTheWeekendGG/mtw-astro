---
import Base from '../layouts/Base.astro';
---
<Base
  title="Coming soon — Made the Weekend"
  description="This guide is still out on the road. Join the Weekend Brief to hear when it lands."
>
<section class="page-head">
  <div class="inner" style="max-width:640px;">
    <svg class="page-motif" width="120" height="44" viewBox="0 0 120 44" fill="none" aria-hidden="true">
  <path d="M4 40 C 30 34, 40 22, 60 20 C 74 18.5, 82 17, 89 14" stroke="#E0A45C" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="0.5 7" opacity="0.8"></path>
  <path d="M98 2 C 101.3 2, 104 4.7, 104 8 C 104 12.5, 98 17.5, 98 17.5 C 98 17.5, 92 12.5, 92 8 C 92 4.7, 94.7 2, 98 2 Z" stroke="#E0A45C" stroke-width="1.4" fill="none"></path>
  <circle cx="98" cy="7.8" r="1.8" fill="#E0A45C"></circle>
</svg>
    <p class="eyebrow">Not yet</p>
    <h1>This one's still out on the road</h1>
    <p class="lede">We only publish a guide once we've actually made the trip, so this page is waiting on a real weekend. It'll appear here the moment it's written.</p>
  </div>
</section>
<section class="light" style="padding-top:clamp(48px,7vw,72px);padding-bottom:clamp(72px,10vw,110px);">
  <div class="wrap" style="max-width:640px;">
    <p style="margin:0 0 24px;color:var(--ink-soft);font-size:16px;line-height:1.7;">Want to know when it lands? The Weekend Brief goes out every Thursday with wherever we've just been.</p>
    <div style="display:flex;gap:14px;flex-wrap:wrap;">
      <a href="/the-weekend-brief" style="background:var(--clay);color:var(--cream);font-size:15px;font-weight:600;padding:14px 26px;border-radius:4px;">Join the Weekend Brief</a>
      <a href="/guides" style="border:1px solid rgba(28,36,29,0.3);color:var(--forest-deep);font-size:15px;font-weight:600;padding:14px 26px;border-radius:4px;">See what's live</a>
    </div>
  </div>
</section>
<!-- ============ FOOTER ============ -->
</Base>
