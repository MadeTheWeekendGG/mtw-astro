---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guide'))
  .filter((g) => g.data.published)
  .map((g) => ({
    title: g.data.title,
    region: g.data.region,
    read: g.data.readTime || '',
    mins: g.data.driveMinsFromLondon ?? null,
    url: `/guides/${g.slug}`,
  }))
  .filter((g) => g.mins != null);
---
<Base
  title="Find trips near me - Made the Weekend"
  description="Sort every UK weekend guide by real drive time from London."
>
<section class="page-head">
  <div class="inner">
    <svg class="page-motif" width="120" height="44" viewBox="0 0 120 44" fill="none" aria-hidden="true">
  <path d="M4 40 C 30 34, 40 22, 60 20 C 74 18.5, 82 17, 89 14" stroke="#E0A45C" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="0.5 7" opacity="0.8"></path>
  <path d="M98 2 C 101.3 2, 104 4.7, 104 8 C 104 12.5, 98 17.5, 98 17.5 C 98 17.5, 92 12.5, 92 8 C 92 4.7, 94.7 2, 98 2 Z" stroke="#E0A45C" stroke-width="1.4" fill="none"></path>
  <circle cx="98" cy="7.8" r="1.8" fill="#E0A45C"></circle>
</svg>
    <p class="eyebrow">Find trips near me</p>
    <h1>Weekends within your reach</h1>
    <p class="lede">Sorted by drive time from London for now. Pick how far you're willing to go, and we'll show what's within reach. As we add guides and starting points, this grows.</p>
  </div>
</section>
<section class="darker" style="padding-top:clamp(40px,6vw,56px);padding-bottom:clamp(72px,10vw,120px);">
  <div class="wrap" style="max-width:900px;">
    <div class="range" role="group" aria-label="Maximum drive time" id="range">
      <button data-h="1">Up to 1 hr</button>
      <button data-h="2">Up to 2 hr</button>
      <button data-h="3" class="active">Up to 3 hr</button>
      <button data-h="5">Up to 5 hr</button>
    </div>
    <button class="btn-search" id="search" style="margin-top:12px;width:100%;">Show weekends</button>
    <div id="results" style="margin-top:30px;"></div>
  </div>
</section>
<script define:vars={{ guides }}>
(function(){
  var rangeH=3;
  var rangeEl=document.getElementById('range');
  rangeEl.addEventListener('click',function(e){
    var b=e.target.closest('button'); if(!b) return;
    Array.prototype.forEach.call(rangeEl.querySelectorAll('button'),function(x){x.classList.remove('active');});
    b.classList.add('active'); rangeH=parseInt(b.getAttribute('data-h'),10);
  });
  function fmt(m){var h=Math.floor(m/60),mm=m%60;return mm===0?h+' hr':h+' hr '+String(mm).padStart(2,'0');}
  function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  document.getElementById('search').addEventListener('click',function(){
    var max=rangeH*60;
    var rows=guides.filter(function(g){return g.mins<=max;}).sort(function(a,b){return a.mins-b.mins;});
    var box=document.getElementById('results');
    if(rows.length===0){box.innerHTML='<p style="color:var(--sage-light);font-size:15px;line-height:1.6;">Nothing we\'ve covered is that close yet. Widen the range, or come back as we add more guides.</p>';return;}
    var html='<p style="color:var(--amber);font-size:13px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 8px;">'+rows.length+' within a '+rangeH+'-hour drive of London</p><div style="border-top:1px solid rgba(244,237,222,0.14);">';
    rows.forEach(function(g){html+='<a class="result" href="'+g.url+'" style="border-bottom:1px solid rgba(244,237,222,0.08);"><span class="t">'+fmt(g.mins)+'</span><span class="n">'+esc(g.title)+'</span><span class="r">'+esc(g.region)+(g.read?' · '+esc(g.read):'')+'</span></a>';});
    html+='</div><p class="results-note">Off-peak drive estimates from central London. Check before you set off.</p>';
    box.innerHTML=html;
  });
})();
</script>
</Base>
