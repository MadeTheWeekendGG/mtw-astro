---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const nearMeGuides = (await getCollection('guide'))
  .filter((g) => g.data.published && g.data.lat != null && g.data.lng != null)
  .map((g) => ({
    title: g.data.title,
    region: g.data.region,
    read: g.data.readTime || '',
    lat: g.data.lat,
    lng: g.data.lng,
    url: `/guides/${g.slug}`,
  }));
---
<Base
  title="Find trips near me - Made the Weekend"
  description="Type where you're starting from and see every UK weekend guide sorted by real drive time."
>
<section class="page-head">
  <div class="inner">
    <svg class="page-motif" width="120" height="44" viewBox="0 0 120 44" fill="none" aria-hidden="true">
  <path d="M4 40 C 30 34, 40 22, 60 20 C 74 18.5, 82 17, 89 14" stroke="#E0A45C" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="0.5 7" opacity="0.8"></path>
  <path d="M98 2 C 101.3 2, 104 4.7, 104 8 C 104 12.5, 98 17.5, 98 17.5 C 98 17.5, 92 12.5, 92 8 C 92 4.7, 94.7 2, 98 2 Z" stroke="#E0A45C" stroke-width="1.4" fill="none"></path>
  <circle cx="98" cy="7.8" r="1.8" fill="#E0A45C"></circle>
</svg>
    <p class="eyebrow">Find trips near me</p>
    <h1>Weekends within your reach</h1>
    <p class="lede">Tell us where you're starting from - a postcode or a town - and we'll sort every guide by real driving time on the road, not as the crow flies.</p>
  </div>
</section>
<section class="darker" style="padding-top:clamp(40px,6vw,56px);padding-bottom:clamp(72px,10vw,120px);">
  <div class="wrap" style="max-width:900px;">
    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:stretch;">
      <input type="text" id="from" placeholder="Your postcode or town (e.g. NR1 or Manchester)" aria-label="Your starting location"
        style="flex:2 1 260px;min-width:0;background:var(--forest);border:1px solid rgba(244,237,222,0.22);border-radius:4px;color:var(--cream);font-family:Inter,sans-serif;font-size:15px;padding:14px 16px;outline:none;">
      <button class="btn-search" id="search" style="flex:1 1 160px;">Show weekends</button>
    </div>
    <div class="range" role="group" aria-label="Maximum drive time" id="range" style="margin-top:12px;">
      <button data-h="1">Up to 1 hr</button>
      <button data-h="2">Up to 2 hr</button>
      <button data-h="3" class="active">Up to 3 hr</button>
      <button data-h="5">Up to 5 hr</button>
    </div>
    <div id="results" style="margin-top:30px;"></div>
  </div>
</section>
<script define:vars={{ nearMeGuides }}>
(function(){
  var rangeH = 3;
  var rangeEl = document.getElementById('range');
  rangeEl.addEventListener('click', function(e){
    var b = e.target.closest('button'); if(!b) return;
    Array.prototype.forEach.call(rangeEl.querySelectorAll('button'), function(x){ x.classList.remove('active'); });
    b.classList.add('active'); rangeH = parseInt(b.getAttribute('data-h'), 10);
  });
  function fmt(mins){ var h = Math.floor(mins/60), m = Math.round(mins%60); return h === 0 ? m + ' min' : (m === 0 ? h + ' hr' : h + ' hr ' + String(m).padStart(2,'0')); }
  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  var box = document.getElementById('results');

  function setStatus(msg){ box.innerHTML = '<p style="color:var(--sage-light);font-size:15px;line-height:1.6;">' + msg + '</p>'; }

  document.getElementById('search').addEventListener('click', function(){
    var from = document.getElementById('from').value.trim();
    if(!from){ document.getElementById('from').focus(); return; }
    setStatus('Working out drive times from ' + esc(from) + '...');

    // 1) Geocode the typed location via Nominatim (OpenStreetMap)
    fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=gb&q=' + encodeURIComponent(from))
      .then(function(r){ return r.json(); })
      .then(function(geo){
        if(!geo || !geo.length){ setStatus('We could not find that place. Try a postcode or a nearby town.'); return; }
        var oLat = parseFloat(geo[0].lat), oLng = parseFloat(geo[0].lon);

        // 2) For each guide, ask OSRM for a real road driving time
        var jobs = nearMeGuides.map(function(g){
          var url = 'https://router.project-osrm.org/route/v1/driving/' + oLng + ',' + oLat + ';' + g.lng + ',' + g.lat + '?overview=false';
          return fetch(url).then(function(r){ return r.json(); }).then(function(d){
            var mins = (d && d.routes && d.routes[0]) ? Math.round(d.routes[0].duration / 60) : null;
            return { g: g, mins: mins };
          }).catch(function(){ return { g: g, mins: null }; });
        });

        Promise.all(jobs).then(function(list){
          var max = rangeH * 60;
          var rows = list.filter(function(x){ return x.mins != null && x.mins <= max; })
                         .sort(function(a,b){ return a.mins - b.mins; });
          if(rows.length === 0){
            setStatus('Nothing within a ' + rangeH + '-hour drive of ' + esc(from) + ' yet. Try a longer drive, or check back as we add guides.');
            return;
          }
          var html = '<p style="color:var(--amber);font-size:13px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 8px;">' + rows.length + ' within a ' + rangeH + '-hour drive of ' + esc(from) + '</p><div style="border-top:1px solid rgba(244,237,222,0.14);">';
          rows.forEach(function(x){
            html += '<a class="result" href="' + x.g.url + '" style="border-bottom:1px solid rgba(244,237,222,0.08);"><span class="t">' + fmt(x.mins) + '</span><span class="n">' + esc(x.g.title) + '</span><span class="r">' + esc(x.g.region) + (x.g.read ? ' · ' + esc(x.g.read) : '') + '</span></a>';
          });
          html += '</div><p class="results-note">Real road drive times from ' + esc(from) + ', off-peak. Check before you set off.</p>';
          box.innerHTML = html;
        });
      })
      .catch(function(){ setStatus('Something went wrong looking that up. Please try again in a moment.'); });
  });
})();
</script>
</Base>
