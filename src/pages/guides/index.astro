    <div class="grid3" id="grid"><a class="g-card" href="/coming-soon" data-moods="Coast|Slow &amp; quiet">
  <div class="thumb"><div class="img" data-ph="Holkham beach, golden hour"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">North Norfolk</p>
    <h3>The coast that earns the drive</h3>
    <p class="meta">2 hr 30 from London · 12 min read</p>
  </div>
</a><a class="g-card" href="/coming-soon" data-moods="City weekends|Food first">
  <div class="thumb"><div class="img" data-ph="Bath — Royal Crescent or the abbey"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">Somerset</p>
    <h3>Bath in a weekend</h3>
    <p class="meta">2 hr 20 from London · 9 min read</p>
  </div>
</a><a class="g-card" href="/coming-soon" data-moods="Hills &amp; big walks">
  <div class="thumb"><div class="img" data-ph="Peak District — a ridge, on foot"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">Derbyshire</p>
    <h3>The Peak District, on foot</h3>
    <p class="meta">3 hr 30 from London · 11 min read</p>
  </div>
</a><a class="g-card" href="/coming-soon" data-moods="Slow &amp; quiet">
  <div class="thumb"><div class="img" data-ph="Wye Valley — river bend from above"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">Monmouthshire</p>
    <h3>A slow weekend in the Wye Valley</h3>
    <p class="meta">2 hr 45 from London · 8 min read</p>
  </div>
</a><a class="g-card" href="/coming-soon" data-moods="Hills &amp; big walks">
  <div class="thumb"><div class="img" data-ph="Lake District — water and fells"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">Cumbria</p>
    <h3>Two days in the Lake District</h3>
    <p class="meta">4 hr 50 from London · 12 min read</p>
  </div>
</a><a class="g-card" href="/coming-soon" data-moods="City weekends|Food first">
  <div class="thumb"><div class="img" data-ph="Edinburgh — closes and rooftops"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">Scotland</p>
    <h3>Edinburgh beyond the Royal Mile</h3>
    <p class="meta">best by train · 10 min read</p>
  </div>
</a><a class="g-card" href="/coming-soon" data-moods="Coast">
  <div class="thumb"><div class="img" data-ph="Whitby harbour"></div></div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    <p class="eyebrow">North Yorkshire</p>
    <h3>Whitby, out of season</h3>
