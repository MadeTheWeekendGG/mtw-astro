---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const CATEGORIES = ['Coast', 'Hills & big walks', 'Food first', 'Slow & quiet', 'City weekends', 'Dog-friendly'];
function catSlug(c) { return c.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''); }

const guides = (await getCollection('guide'))
  .filter((g) => g.data.published)
  .sort((a, b) => (a.data.driveMinsFromLondon ?? 9999) - (b.data.driveMinsFromLondon ?? 9999));

function driveLabel(mins) {
  if (mins == null) return '';
  const h = Math.floor(mins / 60), m = mins % 60;
  return m === 0 ? `${h} hr from London` : `${h} hr ${String(m).padStart(2, '0')} from London`;
}
---
<Base
  title="Guides - Made the Weekend"
  description="Every UK weekend guide we've written, added one real trip at a time."
>
<section class="page-head">
  <div class="inner">
    <svg class="page-motif" width="120" height="44" viewBox="0 0 120 44" fill="none" aria-hidden="true">
  <path d="M4 40 C 30 34, 40 22, 60 20 C 74 18.5, 82 17, 89 14" stroke="#E0A45C" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="0.5 7" opacity="0.8"></path>
  <path d="M98 2 C 101.3 2, 104 4.7, 104 8 C 104 12.5, 98 17.5, 98 17.5 C 98 17.5, 92 12.5, 92 8 C 92 4.7, 94.7 2, 98 2 Z" stroke="#E0A45C" stroke-width="1.4" fill="none"></path>
  <circle cx="98" cy="7.8" r="1.8" fill="#E0A45C"></circle>
</svg>
    <p class="eyebrow">The library</p>
    <h1>Every guide we've written</h1>
    <p class="lede">Written after the trip, not before. Only places someone has genuinely been make it in, so the library grows one weekend at a time.</p>
  </div>
</section>
<section class="light" style="padding-top:clamp(48px,7vw,72px);padding-bottom:clamp(64px,9vw,100px);">
  <div class="wrap">
    <div class="cat-chips" style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:40px;">
      <a href="/guides" class="chip active">All</a>
      {CATEGORIES.map((c) => (
        <a href={`/guides/category/${catSlug(c)}`} class="chip">{c}</a>
      ))}
    </div>
    {guides.length === 0 ? (
      <p style="color:var(--sage);font-size:16px;">The first guides are being written now. Check back soon, or join <a href="/the-weekend-brief" style="font-weight:600;">the Brief</a> to hear when they land.</p>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:32px;">
        {guides.map((g) => (
          <a class="g-card" href={`/guides/${g.slug}`} style="display:flex;flex-direction:column;text-decoration:none;">
            <div class="thumb" style="position:relative;border-radius:6px;overflow:hidden;aspect-ratio:3/2;background:var(--forest);">
              <div class={`img ${g.data.heroImage ? 'has-photo' : ''}`} style={g.data.heroImage ? `background-image:url('${g.data.heroImage}')` : ''} data-ph={g.data.heroAlt || g.data.region}></div>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;padding-top:14px;">
              <p class="eyebrow" style="color:var(--clay);font-size:12px;">{g.data.region}</p>
              <h3 style="font-family:Fraunces,serif;font-weight:600;font-size:22px;line-height:1.15;color:var(--forest-deep);">{g.data.title}</h3>
              <p class="meta" style="margin:0;font-size:13px;color:var(--sage);">{driveLabel(g.data.driveMinsFromLondon)}{g.data.readTime ? ` · ${g.data.readTime}` : ''}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
<style>
  .chip { padding: 9px 18px; border-radius: 999px; border: 1px solid rgba(28,36,29,0.2); font-size: 14px; font-weight: 500; color: var(--forest-deep); background: transparent; transition: all 0.15s ease; }
  .chip:hover { border-color: var(--clay); color: var(--clay); }
  .chip.active { background: var(--forest-deep); color: var(--cream); border-color: var(--forest-deep); }
</style>
</Base>
