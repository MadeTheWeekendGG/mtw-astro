    <p class="eyebrow">Suffolk</p>
    <h3>Aldeburgh &amp; the Suffolk coast</h3>
    <p class="meta">2 hr 35 from London · 8 min read</p>
  </div>
</a></div>
  </div>
</section>
<script>
(function(){
  var chips=document.getElementById('chips'), grid=document.getElementById('grid');
  chips.addEventListener('click',function(e){
    var b=e.target.closest('.chip'); if(!b) return;
    Array.prototype.forEach.call(chips.querySelectorAll('.chip'),function(x){x.classList.remove('active');});
    b.classList.add('active');
    var mood=b.getAttribute('data-mood');
    Array.prototype.forEach.call(grid.querySelectorAll('.g-card'),function(card){
      var moods=card.getAttribute('data-moods').split('|');
      card.style.display=(mood==='All'||moods.indexOf(mood)>-1)?'':'none';
    });
  });
})();
</script>
