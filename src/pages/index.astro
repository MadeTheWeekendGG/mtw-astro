---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import BriefSignup from '../components/BriefSignup.astro';

const published = (await getCollection('guide'))
  .filter((g) => g.data.published)
  .sort((a, b) => (a.data.driveMinsFromLondon ?? 9999) - (b.data.driveMinsFromLondon ?? 9999));

// The hero is whichever guide is flagged featured: true in its front matter.
// If none is flagged, fall back to the nearest to London (the previous behaviour).
const featured = published.find((g) => g.data.featured) || published[0] || null;
const rest = published.filter((g) => g.slug !== featured?.slug);

// Regions for the browse section
const regionSet = Array.from(new Set(published.map((g) => g.data.region))).sort();
function regionSlug(name) { return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''); }

// Data for the near-me tool (client-side) - needs coordinates
const nearMeGuides = published
  .filter((g) => g.data.lat != null && g.data.lng != null)
  .map((g) => ({ title: g.data.title, region: g.data.region, read: g.data.readTime || '', lat: g.data.lat, lng: g.data.lng, url: `/guides/${g.slug}` }));

function driveLabel(mins) {
  if (mins == null) return '';
  const h = Math.floor(mins / 60), m = mins % 60;
  return m === 0 ? `${h} hr from London` : `${h} hr ${String(m).padStart(2, '0')} from London`;
}
---
<Base
  title="Made the Weekend - UK weekend getaways worth the drive"
  description="First-hand guides to UK weekends worth the drive. Where to go, where to stay, and what's actually worth it, written one trip at a time."
>
<!-- ============ HERO ============ -->
<section class="hero">
  <div class={`img ${featured?.data.heroImage ? 'has-photo' : ''}`} id="hero-img" style={featured?.data.heroImage ? `background-image:url('${featured.data.heroImage}');background-size:cover;background-position:center;` : ''} data-ph={featured?.data.heroAlt || 'Made the Weekend'}></div>
  <div class="hero-shade"></div>
  <svg class="hero-motif" width="220" height="120" viewBox="0 0 220 120" fill="none" aria-hidden="true">
    <path d="M6 112 C 50 100, 60 66, 104 58 C 140 51, 156 44, 166 34" stroke="#E0A45C" stroke-width="2" stroke-linecap="round" stroke-dasharray="0.5 9"></path>
    <path d="M178 4 C 183.5 4, 188 8.5, 188 14 C 188 21.5, 178 30, 178 30 C 178 30, 168 21.5, 168 14 C 168 8.5, 172.5 4, 178 4 Z" stroke="#E0A45C" stroke-width="1.6" fill="none"></path>
    <circle cx="178" cy="13.6" r="3" fill="#E0A45C"></circle>
  </svg>
  <div class="hero-content">
    <div class="inner">
      <div class="hero-copy">
        {featured ? (
          <>
            <p class="eyebrow" style="color:var(--amber);">{featured.data.region} · Worth the drive</p>
            <h1>{featured.data.title}</h1>
            {featured.data.standfirst && <p class="hero-standfirst">{featured.data.standfirst}</p>}
            <p class="hero-meta">{driveLabel(featured.data.driveMinsFromLondon)}{featured.data.readTime ? ` · ${featured.data.readTime}` : ''}</p>
            <a class="btn-clay" href={`/guides/${featured.slug}`}>Read the guide<span aria-hidden="true" style="font-size:17px;line-height:1;">→</span></a>
          </>
        ) : (
          <>
            <p class="eyebrow" style="color:var(--amber);">UK weekends worth the drive</p>
            <h1>Trips worth the drive</h1>
            <p class="hero-standfirst">First-hand guides to UK weekends. The first ones are being written now.</p>
            <a class="btn-clay" href="/the-weekend-brief">Join the Brief<span aria-hidden="true" style="font-size:17px;line-height:1;">→</span></a>
          </>
        )}
      </div>
    </div>
  </div>
</section>

<!-- ============ NEAR ME TOOL ============ -->
<section class="nearme-sec" id="near-me">
  <div class="nearme">
    <div class="nearme-head">
      <h2>Weekends within your reach</h2>
      <p>Sorted by real driving time from wherever you are.</p>
    </div>
    <div class="nearme-controls">
      <input type="text" id="from" placeholder="Your postcode or town" aria-label="Your starting location">
      <div class="range" role="group" aria-label="Maximum drive time" id="range">
        <button data-h="1">1 hr</button>
        <button data-h="2">2 hr</button>
        <button data-h="3" class="active">3 hr</button>
        <button data-h="5">5 hr</button>
      </div>
      <button class="btn-search" id="search">Show weekends</button>
    </div>
    <div class="results" id="results" hidden></div>
  </div>
</section>

<!-- ============ THIS WEEKEND'S PICKS ============ -->
{published.length > 0 && (
  <section class="light pad-picks">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <p class="eyebrow" style="color:var(--clay);margin-bottom:10px;">Where we'd go</p>
          <h2 id="picks-heading">The guides so far</h2>
        </div>
        <a class="link-more" href="/guides">All guides →</a>
      </div>
      <div style="display:flex;gap:24px;flex-wrap:wrap;">
        <a class="card" href={`/guides/${featured.slug}`} style="flex:5 1 480px;min-height:500px;">
          <div class={`img ${featured.data.heroImage ? 'has-photo' : ''}`} style={featured.data.heroImage ? `background-image:url('${featured.data.heroImage}')` : ''} data-ph={featured.data.heroAlt || featured.data.region}></div>
          <div class="card-shade"></div>
          <div class="card-cap">
            <p class="eyebrow">{featured.data.region}</p>
            <h3 style="font-size:clamp(26px,3.4vw,38px);line-height:1.08;letter-spacing:-0.015em;">{featured.data.title}</h3>
            <p>{driveLabel(featured.data.driveMinsFromLondon)}{featured.data.readTime ? ` · ${featured.data.readTime}` : ''}</p>
          </div>
        </a>
        {rest.length > 0 && (
          <div style="flex:3 1 300px;display:flex;flex-direction:column;gap:24px;">
            {rest.slice(0, 2).map((g) => (
              <a class="tile" href={`/guides/${g.slug}`} style="flex:1;">
                <div class="thumb" style="height:170px;position:relative;overflow:hidden;border-radius:6px;">
                  <div class={`img ${g.data.heroImage ? 'has-photo' : ''}`} style={g.data.heroImage ? `background-image:url('${g.data.heroImage}')` : ''} data-ph={g.data.heroAlt || g.data.region}></div>
                </div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <p class="eyebrow">{g.data.region}</p>
                  <h3>{g.data.title}</h3>
                  <p class="meta">{driveLabel(g.data.driveMinsFromLondon)}{g.data.readTime ? ` · ${g.data.readTime}` : ''}</p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
)}

<!-- ============ BROWSE BY REGION / MOOD ============ -->
<section class="darker">
  <div class="wrap" style="padding-top:clamp(64px,9vw,100px);padding-bottom:clamp(64px,9vw,100px);">
    <div class="browse">
      <div class="col">
        <p class="eyebrow">Browse by region</p>
        <h2>Where do you fancy?</h2>
        <div class="region-list">
          {regionSet.length > 0 ? regionSet.map((r) => (
            <a href={`/regions/${regionSlug(r)}`}>{r} <span aria-hidden="true">→</span></a>
          )) : (
            <a href="/regions">All regions <span aria-hidden="true">→</span></a>
          )}
        </div>
      </div>
      <div class="col">
        <p class="eyebrow">Or by the kind of weekend</p>
        <h2>What's the mood?</h2>
        <div class="moods">
          <a href="/guides/category/coast">Coast</a>
          <a href="/guides/category/hills-and-big-walks">Hills &amp; big walks</a>
          <a href="/guides/category/food-first">Food first</a>
          <a href="/guides/category/slow-and-quiet">Slow &amp; quiet</a>
          <a href="/guides/category/city-weekends">City weekends</a>
          <a href="/guides/category/family-friendly">Family friendly</a>
          <a href="/guides/category/dog-friendly">With the dog</a>
        </div>
        <p class="note">Every guide is written after a real trip, so both lists grow one weekend at a time.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ NEWSLETTER ============ -->
<section class="light" style="border-bottom:1px solid rgba(28,36,29,0.12);">
  <BriefSignup variant="section" />
</section>

</Base>

<script define:vars={{ nearMeGuides }}>
(function () {
  // ---- Find trips near me (real road routing) ----
  var guides = nearMeGuides;
  var rangeH = 3;
  var rangeEl = document.getElementById('range');
  rangeEl.addEventListener('click', function (e) {
    var b = e.target.closest('button'); if (!b) return;
    rangeH = parseInt(b.getAttribute('data-h'), 10);
    Array.prototype.forEach.call(rangeEl.querySelectorAll('button'), function (x) { x.classList.remove('active'); });
    b.classList.add('active');
  });
  function fmt(mins) { var h = Math.floor(mins / 60), m = Math.round(mins % 60); return h === 0 ? m + ' min' : (m === 0 ? h + ' hr' : h + ' hr ' + String(m).padStart(2, '0')); }
  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  var box = document.getElementById('results');
  function setStatus(msg){ box.hidden = false; box.innerHTML = '<p class="results-note">' + msg + '</p>'; }
  document.getElementById('search').addEventListener('click', function () {
    var from = document.getElementById('from').value.trim();
    if (!from) { document.getElementById('from').focus(); return; }
    setStatus('Working out drive times from ' + esc(from) + '...');
    fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=gb&q=' + encodeURIComponent(from))
      .then(function (r) { return r.json(); })
      .then(function (geo) {
        if (!geo || !geo.length) { setStatus('We could not find that place. Try a postcode or a nearby town.'); return; }
        var oLat = parseFloat(geo[0].lat), oLng = parseFloat(geo[0].lon);
        var jobs = guides.map(function (g) {
          var url = 'https://router.project-osrm.org/route/v1/driving/' + oLng + ',' + oLat + ';' + g.lng + ',' + g.lat + '?overview=false';
          return fetch(url).then(function (r) { return r.json(); }).then(function (d) {
            var mins = (d && d.routes && d.routes[0]) ? Math.round(d.routes[0].duration / 60) : null;
            return { g: g, mins: mins };
          }).catch(function () { return { g: g, mins: null }; });
        });
        Promise.all(jobs).then(function (list) {
          var max = rangeH * 60;
          var rows = list.filter(function (x) { return x.mins != null && x.mins <= max; }).sort(function (a, b) { return a.mins - b.mins; });
          if (rows.length === 0) { setStatus('Nothing within a ' + rangeH + '-hour drive of ' + esc(from) + ' yet. Try a longer drive.'); return; }
          var html = '';
          rows.forEach(function (x) {
            html += '<a class="result" href="' + x.g.url + '"><span class="t">' + fmt(x.mins) + '</span>' +
              '<span class="n">' + esc(x.g.title) + '</span><span class="r">' + esc(x.g.region) + '</span></a>';
          });
          html += '<p class="results-note">Real road drive times from ' + esc(from) + ', off-peak. Check before you set off.</p>';
          box.innerHTML = html; box.hidden = false;
        });
      })
      .catch(function () { setStatus('Something went wrong looking that up. Please try again.'); });
  });

})();
</script>
